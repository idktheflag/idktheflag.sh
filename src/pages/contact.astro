---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Contact idktheflag.">
  <section class="section contact">
    <div class="container contact__inner">
      <p>
        For inquiries regarding partnerships or join applications, contact the captain by email at
        qu1ck5h0t[at]hotmail.com. If you would prefer to use Discord, his username is Qu1ck5h0t.
      </p>
      <p>
        Our <a href="https://discord.gg/VzjtumpgfQ">academy team</a> is open to everyone (new
        players are highly encouraged to apply), and active players will be invited to the main team
        (highly experienced players may want to contact the captain directly instead).
      </p>
      <p>
        <a href="/">back to home</a>
      </p>
    </div>
  </section>
</Base>

<style>
  .contact__inner {
    max-width: var(--maxw-prose);
  }
  .contact p + p {
    margin-top: 1em;
  }
  .contact a {
    color: var(--crimson-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--crimson-line);
  }
  .contact a:hover {
    text-decoration-color: var(--crimson-bright);
  }
</style>
