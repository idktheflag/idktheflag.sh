---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Not found" description="That flag isn't here.">
  <section class="nf">
    <div class="container nf__inner">
      <span class="nf__code">404</span>
      <h1 class="nf__title">We couldn&rsquo;t find it.</h1>
      <p class="nf__text">
        This one stayed hidden. The page you&rsquo;re looking for doesn&rsquo;t exist —
        or it moved somewhere we haven&rsquo;t flagged yet.
      </p>
      <div class="nf__cta">
        <a class="btn btn-primary" href="/">Back home</a>
        <a class="btn btn-ghost" href="/ctf">See our CTF stats</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 64vh;
    display: grid;
    place-items: center;
    text-align: center;
    padding-block: 80px;
  }
  .nf__code {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 16vw, 9rem);
    font-weight: 700;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--crimson);
    text-stroke: 1.5px var(--crimson);
    letter-spacing: -0.04em;
  }
  .nf__title {
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    margin-top: 18px;
  }
  .nf__text {
    max-width: 48ch;
    margin: 16px auto 0;
    color: var(--muted);
  }
  .nf__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 28px;
  }
</style>
